{
  "name": "drinks",
  "version": "4.2.0",
  "private": true,
  "description": "Craft Cocktail Gallery",
  "bugs": {
    "url": "https://github.com/wKovacs64/drinks/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin Hall",
    "email": "justin.r.hall@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wKovacs64/drinks.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#/*": "./*"
  },
  "scripts": {
    "clean": "del-cli .cache app/ui/icons/icons-sprite.svg app/ui/icons/types.ts build node_modules/.vite public/sw.js",
    "build": "run-s build:*",
    "build:rr": "react-router build",
    "build:sw": "esbuild app/entry.worker.ts --minify --platform=browser --format=esm --outfile=build/client/sw.js",
    "deploy": "flyctl deploy --remote-only",
    "dev": "run-p dev:rr dev:sw",
    "dev:rr": "react-router dev",
    "dev:test": "dotenv -e .env.test -- react-router dev",
    "dev:sw": "esbuild app/entry.worker.ts --watch --platform=browser --format=esm --outfile=public/sw.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "cross-env NODE_ENV=production PORT=8080 node ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "validate": "run-p format:check lint typecheck test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui"
  },
  "dependencies": {
    "@coji/remix-auth-google": "4.2.0",
    "@epic-web/invariant": "1.0.0",
    "@epic-web/remember": "1.1.0",
    "@fontsource/source-sans-3": "5.2.9",
    "@imagekit/nodejs": "7.5.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "@remix-run/form-data-parser": "0.16.0",
    "@sindresorhus/slugify": "3.0.0",
    "@unpic/react": "1.0.2",
    "better-sqlite3": "12.9.0",
    "clsx": "2.1.1",
    "cross-env": "10.1.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "is-ip": "5.0.1",
    "isbot": "5.1.39",
    "lodash-es": "4.18.1",
    "marked": "18.0.2",
    "minisearch": "7.2.0",
    "picocolors": "1.1.1",
    "pretty-cache-header": "1.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-image-crop": "11.0.10",
    "react-router": "7.14.2",
    "react-router-hono-server": "2.25.3",
    "remix-auth": "4.2.0",
    "remix-auth-oauth2": "3.4.1",
    "remix-utils": "9.3.1",
    "sonner": "2.0.7",
    "unpic": "4.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@react-router/dev": "7.14.2",
    "@react-router/fs-routes": "7.14.2",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.2.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/lodash-es": "4.17.12",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@wkovacs64/add-icon": "1.2.2",
    "@wkovacs64/eslint-config": "7.14.0",
    "babel-plugin-react-compiler": "1.0.0",
    "del-cli": "7.0.0",
    "dotenv-cli": "11.0.0",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "msw": "2.13.5",
    "node-html-parser": "7.1.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.46.0",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "vite": "8.0.9",
    "vite-plugin-icons-spritesheet": "3.0.1",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
